# ============================================================
# Wonder World Westgate — Environment Variables
# Copy this to .env.local for local dev (never commit .env.local)
# These same keys go into Vercel → Settings → Environment Variables
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...          # "anon public" key — safe to expose in frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # NEVER expose — Edge Functions only

# ── Stripe ───────────────────────────────────────────────────
# Found in: dashboard.stripe.com → Developers → API keys
STRIPE_PUBLIC_KEY=pk_live_...     # or pk_test_... for testing
STRIPE_SECRET_KEY=sk_live_...     # NEVER expose — Edge Functions only
STRIPE_WEBHOOK_SECRET=whsec_...   # Stripe Dashboard → Webhooks → signing secret

# ── Resend (email) ───────────────────────────────────────────
# Found in: resend.com → API Keys
# Requires a verified sending domain (e.g. wonderworldwestgate.co.nz)
RESEND_API_KEY=re_...

# ── Twilio (SMS) ─────────────────────────────────────────────
# Found in: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+64...        # Your Twilio NZ number in E.164 format

# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=production            # or "development"
